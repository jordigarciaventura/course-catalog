---
import { LanguageSelect } from "@/components/CourseHero/LanguageSelect";
import { Toggle } from "astro-theme-toggle";
import { creator } from "@/config";
---

<div class="flex justify-between items-center w-full">
    <p class="ml-8 text-sm sm:text-base text-white">{creator}</p>
    <div class="flex items-center gap-6">
        <div class="size-5 text-white">
            <Toggle />
        </div>
        <LanguageSelect client:load />
    </div>
</div>

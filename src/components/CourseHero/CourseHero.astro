---
import TopBar from "@/components/CourseHero/TopBar.astro";
import Hero from "@/components/CourseHero/Hero.astro";

interface Props {
  courseStats: {
    totalCourses: number;
    totalHours: number;
    firstYear: number;
  };
}

const { courseStats } = Astro.props;
---

<div
  id="header"
  class="fixed top-0 right-0 left-0 z-10 w-full bg-gradient-to-br from-indigo-500 via-purple-600 to-pink-600 p-4 pb-24 dark:from-slate-800 dark:via-slate-900 dark:to-indigo-950"
>
  <TopBar />
  <Hero
    totalCourses={courseStats.totalCourses}
    totalHours={courseStats.totalHours}
    firstYear={courseStats.firstYear}
  />
</div>

<div id="header-spacer"></div>

<script>
  import { initializeHeroAnimation, refreshHeroAnimation, killHeroAnimation } from "@/scripts/heroAnimation.ts";

  // Keep the header spacer height in sync with the header height

  function synchronizeHeaderSpacer() {
    const header = document.getElementById("header");
    const headerSpacer = document.getElementById("header-spacer");

    if (header && headerSpacer) {
      const headerHeight = header.offsetHeight;
      headerSpacer.style.height = `${headerHeight}px`;
    }
  }

  function setupEventListeners() {
    document.addEventListener("DOMContentLoaded", () => {
      synchronizeHeaderSpacer();
      // Small delay to ensure all elements are rendered
      setTimeout(() => {
        initializeHeroAnimation();
      }, 100);
    });

    window.addEventListener("resize", () => {
      synchronizeHeaderSpacer();
      refreshHeroAnimation();
    });

    document.addEventListener("astro:before-swap", () => {
      // Clean up animations before page swap
      killHeroAnimation();
    });

    document.addEventListener("astro:after-swap", () => {
      synchronizeHeaderSpacer();
      setTimeout(() => {
        initializeHeroAnimation();
      }, 100);
    });

    if (typeof ResizeObserver !== "undefined") {
      const header = document.getElementById("header");
      if (header) {
        const resizeObserver = new ResizeObserver(() => {
          synchronizeHeaderSpacer();
          refreshHeroAnimation();
        });
        resizeObserver.observe(header);
      }
    }
  }

  // Initialize immediately if DOM is already loaded
  if (document.readyState === "loading") {
    setupEventListeners();
  } else {
    synchronizeHeaderSpacer();
    setTimeout(() => {
      initializeHeroAnimation();
    }, 100);
    setupEventListeners();
  }
</script>

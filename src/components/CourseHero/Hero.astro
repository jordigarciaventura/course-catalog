---
import { getLangFromUrl, useTranslation } from "@/i18n/utils";
import { Calendar, CheckCircle, Clock } from "@lucide/astro";
import StatsCard from "./StatsCard.astro";

interface Props {
  totalCourses?: number;
  totalHours?: number;
  firstYear?: number;
}

const { totalCourses = 5, totalHours = 130, firstYear = 2020 } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslation(lang);
---

<div id="hero-container" class="relative mt-16 flex w-full flex-col items-center py-10">
  <!-- Background pattern for glassmorphism effect -->
  <div id="hero-background" class="absolute inset-0 opacity-30 dark:opacity-20 will-change-transform">
    <div
      class="absolute top-10 left-10 h-32 w-32 rounded-full bg-white blur-xl dark:bg-slate-300"
    >
    </div>
    <div
      class="absolute top-40 right-20 h-24 w-24 rounded-full bg-yellow-200 blur-lg dark:bg-blue-400"
    >
    </div>
    <div
      class="absolute bottom-20 left-1/3 h-40 w-40 rounded-full bg-pink-200 blur-2xl dark:bg-purple-400"
    >
    </div>
    <div
      class="absolute right-10 bottom-10 h-28 w-28 rounded-full bg-blue-200 blur-xl dark:bg-indigo-400"
    >
    </div>
  </div>

  <div id="hero-content" class="flex max-w-3xl flex-col items-center will-change-transform">
    <h1
      class="mb-4 text-center text-2xl font-bold text-balance text-white sm:text-4xl"
    >
      {t("index.title")}
    </h1>
    <p
      class="text-md mb-8 text-center text-balance text-white/95 sm:text-lg dark:text-slate-100/95"
    >
      {t("index.subtitle")}
    </p>
  </div>

  <!-- Stats Cards -->
  <div id="hero-stats" class="relative z-10 mt-8 flex w-full max-w-xl gap-4 px-4 sm:gap-8 will-change-transform">
    <StatsCard
      value={totalCourses.toString()}
      label={t("index.coursesCompleted")}
    >
      <CheckCircle class="size-5 sm:size-8" slot="icon" />
    </StatsCard>
    <StatsCard value={`${totalHours}h`} label={t("index.totalHours")}>
      <Clock class="size-5 sm:size-8" slot="icon" />
    </StatsCard>
    <StatsCard value={firstYear.toString()} label={t("index.learningSince")}>
      <Calendar class="size-5 sm:size-8" slot="icon" />
    </StatsCard>
  </div>
</div>

<style>
  #hero-content,
  #hero-stats,
  #hero-background {
    transform: translateZ(0); /* Enable hardware acceleration */
    backface-visibility: hidden; /* Improve performance */
  }
  
  #hero-background {
    transform-origin: center center; /* Ensure scaling and rotation from center */
  }
</style>

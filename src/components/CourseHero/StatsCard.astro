---
export interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div
  class="flex h-32 w-full flex-col items-center justify-center rounded-xl border border-white/20 bg-white/10 shadow-lg backdrop-blur-md transition-all duration-300 hover:bg-white/20 sm:h-48 dark:border-slate-300/20 dark:bg-slate-800/30 dark:hover:bg-slate-700/40"
>
  <div
    class="mb-2 flex w-full items-center justify-center text-white sm:mb-4 dark:text-slate-100"
  >
    <slot name="icon" />
  </div>
  <span
    class="mb-1 text-center text-lg font-bold text-white sm:text-2xl dark:text-slate-100"
    >{value}</span
  >
  <span
    class="block w-full px-2 text-center text-xs leading-relaxed whitespace-pre-line text-white/80 sm:text-sm dark:text-slate-200/80"
    >{label}</span
  >
</div>

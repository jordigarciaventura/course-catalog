---
export interface Props {
    value: string;
    label: string;
}

const { value, label } = Astro.props;
---

<div
    class="flex flex-col items-center justify-center h-32 sm:h-48 w-full rounded-xl border border-white/20 dark:border-slate-300/20 bg-white/10 dark:bg-slate-800/30 backdrop-blur-md shadow-lg hover:bg-white/20 dark:hover:bg-slate-700/40 transition-all duration-300"
>
    <div
        class="flex items-center justify-center w-full mb-2 sm:mb-4 text-white dark:text-slate-100"
    >
        <slot name="icon" />
    </div>
    <span
        class="text-lg sm:text-2xl font-bold mb-1 text-white dark:text-slate-100 text-center"
        >{value}</span
    >
    <span
        class="block w-full text-xs sm:text-sm text-white/80 dark:text-slate-200/80 text-center leading-relaxed whitespace-pre-line px-2"
        >{label}</span
    >
</div>

---
interface Props {
    frequencyX?: string;
    frequencyY?: string;
    blurX?: string;
    blurY?: string;
    numOctaves?: string;
    color1?: string;
    color2?: string;
    type?: "linear" | "radial";
    angle?: string; // For linear gradient
}

const {
    frequencyX = "0.001",
    frequencyY = "0.001",
    blurX = "0",
    blurY = "0",
    numOctaves = "1",
    color1 = "hsl(0, 0%, 100%)",
    color2 = "hsl(0, 0%, 0%)",
    angle = "150",
    type = "linear",
} = Astro.props;

const uniqueId = Math.random().toString(36).substring(2, 10);
const gradientId = `gradient-${uniqueId}`;
const filterId = `filter-${uniqueId}`;
---

<svg
    xmlns="http://www.w3.org/2000/svg"
    version="1.1"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    width="100%"
    height="100%"
    opacity="1"
    preserveAspectRatio="none"
>
    <defs>
        {
            type === "radial" ? (
                <radialGradient id={gradientId}>
                    <stop offset="0%" stop-color={color1} />
                    <stop offset="100%" stop-color={color2} />
                </radialGradient>
            ) : (
                <linearGradient
                    gradientTransform={`rotate(${angle}, 0.5, 0.5)`}
                    x1="50%"
                    y1="0%"
                    x2="50%"
                    y2="100%"
                    id={gradientId}
                >
                    <stop stop-color={color1} stop-opacity="1" offset="0%" />
                    <stop stop-color={color2} stop-opacity="1" offset="100%" />
                </linearGradient>
            )
        }
        <filter
            id={filterId}
            x="-20%"
            y="-20%"
            width="140%"
            height="140%"
            filterUnits="objectBoundingBox"
            primitiveUnits="userSpaceOnUse"
            color-interpolation-filters="sRGB"
        >
            <feTurbulence
                type="fractalNoise"
                baseFrequency={`${frequencyX} ${frequencyY}`}
                numOctaves={numOctaves}
                seed="2"
                stitchTiles="stitch"
                x="0%"
                y="0%"
                width="100%"
                height="100%"
                result="turbulence"></feTurbulence>
            <feGaussianBlur
                stdDeviation={`${blurX} ${blurY}`}
                x="0%"
                y="0%"
                width="100%"
                height="100%"
                in="turbulence"
                edgeMode="duplicate"
                result="blur"></feGaussianBlur>
            <feBlend
                mode="color-dodge"
                x="0%"
                y="0%"
                width="100%"
                height="100%"
                in="SourceGraphic"
                in2="blur"
                result="blend"></feBlend>
        </filter>
    </defs>

    <rect
        width="100%"
        height="100%"
        fill={`url(#${gradientId})`}
        filter={`url(#${filterId})`}></rect>
</svg>

---
import SvgPattern from "./SvgPattern.astro";

interface Props {
    value: string;
}

const { value } = Astro.props;

const frequencyMin = 0.001;
const frequencyMax = 0.007;

const blurMin = 0;
const blurMax = 100;

const numOctavesMin = 1;
const numOctavesMax = 2;

const types = ["linear", "radial"];

// Simple hash function to turn string into a number
function hashString(str: string) {
    let hash = 0;
    for (let i = 0; i < str.length; i++) {
        hash = (hash << 5) - hash + str.charCodeAt(i);
        hash |= 0; // Convert to 32bit integer
    }
    return Math.abs(hash);
}

// Simple seeded PRNG
function mulberry32(seed: number) {
    return function () {
        let t = (seed += 0x6d2b79f5);
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
}

const seed = hashString(value);
const random = mulberry32(seed);

function randomBetween(min: number, max: number) {
    return random() * (max - min) + min;
}

function randomIntBetween(min: number, max: number) {
    return Math.floor(random() * (max - min + 1)) + min;
}

function randomColor() {
    const letters = "0123456789ABCDEF";
    let color = "#";
    for (let i = 0; i < 6; i++) {
        color += letters[Math.floor(random() * 16)];
    }
    return color;
}

function randomAngle() {
    return `${Math.floor(random() * 360)}`;
}

const randomFrequencyX = randomBetween(frequencyMin, frequencyMax).toFixed(4);
const randomFrequencyY = randomBetween(frequencyMin, frequencyMax).toFixed(4);

const randomBlurX = randomBetween(blurMin, blurMax).toFixed(2);
const randomBlurY = randomBetween(blurMin, blurMax).toFixed(2);

const randomNumOctaves = randomIntBetween(
    numOctavesMin,
    numOctavesMax
).toString();

const randomColor1 = randomColor();
const randomColor2 = randomColor();

const randomType = types[Math.floor(random() * types.length)] as
    | "linear"
    | "radial";
const randomAngleValue = randomType === "linear" ? randomAngle() : undefined;

console.log(randomColor1);
---

<SvgPattern
    frequencyX={randomFrequencyX}
    frequencyY={randomFrequencyY}
    blurX={randomBlurX}
    blurY={randomBlurY}
    numOctaves={randomNumOctaves}
    color1={randomColor1}
    color2={randomColor2}
    type={randomType}
    angle={randomAngleValue}
/>

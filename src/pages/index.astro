---
import { CourseCard } from "@/components/CourseCard";
import { LanguageSelect } from "@/components/LanguageSelect";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslation } from "@/i18n/useTranslation";
import type { Language } from "@/types";
import { Toggle } from "astro-theme-toggle";
import { getAllCourses } from "@/lib/courseLoader";

// Get all courses from the .tsx files
const courses = await getAllCourses();

// Get current language (defaulting to English for now)
const currentLanguage: Language = "en";
const t = useTranslation(currentLanguage);
---

<BaseLayout>
    <div
        class="flex flex-col items-center min-h-screen bg-background text-foreground"
    >
        <div class="flex flex-col w-full max-w-4xl gap-8 p-8">
            <div class="flex justify-between items-center">
                <h1>{t("index.title")}</h1>
                <Toggle style="width: 32px; height: 32px;" />
                <LanguageSelect
                    currentLanguage={currentLanguage}
                    className="w-48"
                    client:load
                />
            </div>
            <div
                class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 auto-rows-max"
            >
                {
                    courses.map((course) => {
                        const title = course.title[currentLanguage];
                        const description = course.description[currentLanguage];

                        // Determine if title is long (more than 50 characters)
                        const hasLongTitle = title.length > 50;

                        // Determine if description is long (more than 150 characters)
                        const hasLongDescription = description.length > 150;

                        // Build dynamic classes for grid spanning
                        const gridClasses = [
                            hasLongTitle ? "sm:col-span-2 md:col-span-2" : "",
                            hasLongDescription ? "row-span-2" : "",
                        ]
                            .filter(Boolean)
                            .join(" ");

                        return (
                            <div class={gridClasses}>
                                <CourseCard
                                    course={course}
                                    currentLanguage={currentLanguage}
                                    className="h-full"
                                />
                            </div>
                        );
                    })
                }
            </div>
        </div>
    </div>
</BaseLayout>

---
import Course from "@/components/Course.astro";
import RandomSvgPattern from "@/components/RandomSvgPattern.astro";
import Timeline from "@/components/Timeline.astro";
import {
    Card,
    CardContent,
    CardDescription,
    CardHeader,
    CardTitle,
} from "@/components/ui/card";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CalendarIcon, Clock } from "@lucide/astro";

import { getCollection } from "astro:content";

const courseFiles = await getCollection("courses");
const courses = courseFiles.flatMap((file) => file.data);
---

<BaseLayout>
    <div class="flex flex-col items-center">
        <div class="flex flex-col w-full max-w-4xl gap-8 p-8">
            <h1>Courses</h1>
            <ul class="flex flex-col gap-4">
                {
                    courses.map((course) => (
                        <Course
                            title={course.title}
                            duration={course.duration}
                            date={course.date}
                        />
                    ))
                }
            </ul>
        </div>
    </div>
</BaseLayout>

---
import { CourseCard } from "@/components/CourseCard";
import { LanguageSelect } from "@/components/LanguageSelect";
import { CategorySelect } from "@/components/CategorySelect";
import { CourseGrid } from "@/components/CourseGrid";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslation } from "@/i18n/useTranslation";
import type { Language } from "@/types";
import { Toggle } from "astro-theme-toggle";
import { getAllCourses } from "@/lib/courseLoader";
import { getCurrentLanguageFromPath } from "@/lib/language";
import { languages } from "@/config";

// Get the language from the URL parameter (or undefined for default route)
const { lang } = Astro.params;

// Get current language from URL path
const currentLanguage: Language = getCurrentLanguageFromPath(
    Astro.url.pathname
);

// Validate the language parameter if it exists
if (lang && !languages.includes(lang as Language)) {
    return Astro.redirect("/404");
}

// Get all courses from the .tsx files
const courses = await getAllCourses();

// Get translations for current language
const t = useTranslation(currentLanguage);

// Generate static paths for all supported languages
export async function getStaticPaths() {
    return [
        // Default language route (no prefix)
        { params: { lang: undefined } },
        // All other language routes
        ...languages
            .filter((lang) => lang !== "en") // Exclude default language
            .map((lang) => ({
                params: { lang },
            })),
    ];
}
---

<BaseLayout>
    <div
        class="flex flex-col items-center min-h-screen bg-background text-foreground"
    >
        <div class="flex flex-col w-full max-w-4xl gap-8 p-8">
            <div class="flex justify-between items-center">
                <h1>{t("index.title")}</h1>
                <Toggle style="width: 32px; height: 32px;" />
                <LanguageSelect className="w-48" client:load />
            </div>
            <CourseGrid
                courses={courses}
                currentLanguage={currentLanguage}
                client:load
            />
        </div>
    </div>
</BaseLayout>
